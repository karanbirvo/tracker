<?php


$db_host = 'tracker_db';
$db_name = 'tracker'; // Choose your DB name
$db_user = 'tracker';            // Your DB username
$db_pass = 'trackerpass';  

// --- THE FIX IS HERE ---
// This array tells PDO to execute a command right after connecting.
$db_options = [
    PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
    PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
    PDO::ATTR_EMULATE_PREPARES   => false,
    // This command sets the timezone for the current connection to IST (+05:30).
    PDO::MYSQL_ATTR_INIT_COMMAND => "SET time_zone = '+05:30'" 
];
// --- END OF FIX ---

// Database Connection
try {
    // We pass the new options array into the connection.
    $pdo = new PDO("mysql:host=$db_host;dbname=$db_name;charset=utf8mb4", $db_user, $db_pass, $db_options);
} catch (PDOException $e) {
    die("Database connection failed: " . $e->getMessage());
}

// Start Session Safely
if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

// Set PHP's timezone as well for consistency
date_default_timezone_set('Asia/Kolkata');

